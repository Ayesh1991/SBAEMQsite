          { "id": "sba1", "stem": "A woman with three previous second-trimester losses and painless cervical dilatation is seen at 13 weeks.", "lead": "What is the most appropriate management?", "options": ["Expectant management", "History-indicated (elective) cervical cerclage", "Vaginal progesterone only", "Emergency cerclage at 24 weeks", "Serial cervical length scans alone"], "answer": 1, "rationale": "A history of three or more second-trimester losses or preterm births is an indication for history-indicated (elective) cerclage, usually placed at 12-14 weeks.", "hook": "3+ mid-trimester losses -> history-indicated cerclage." },
          { "id": "sba2", "stem": "A woman with one previous preterm birth has a cervical length of 24 mm at 20 weeks on transvaginal scan.", "lead": "What is the most appropriate intervention?", "options": ["Reassurance", "Ultrasound-indicated cerclage or vaginal progesterone", "Immediate delivery", "Bed rest only", "Cervical pessary as first line"], "answer": 1, "rationale": "A short cervix (25 mm or less before 24 weeks) with prior spontaneous preterm birth is an indication for ultrasound-indicated cerclage or vaginal progesterone.", "hook": "Prior PTB + short cervix -> ultrasound-indicated cerclage." },
          { "id": "sba3", "stem": "A woman at 22 weeks has painless dilatation with exposed membranes at the external os and no contractions or infection.", "lead": "What is the most appropriate option?", "options": ["Rescue (emergency) cerclage", "Immediate termination", "Elective caesarean", "Tocolysis alone", "Antibiotics alone"], "answer": 0, "rationale": "In the absence of infection, bleeding or contractions, a rescue (emergency) cerclage can be offered for exposed membranes to prolong the pregnancy.", "hook": "Exposed membranes, no infection -> rescue cerclage." }
