# Cloudflare Pages headers.
# The HTML shell must always be re-fetched so a new release is picked up
# immediately (this is what caused the "I uploaded but nothing changed"
# problem — an old index.html was cached and never loaded the new scripts).
/
  Cache-Control: no-cache, must-revalidate
/index.html
  Cache-Control: no-cache, must-revalidate

# Versioned assets (js/…?v=N, css/…?v=N) are safe to cache hard — the ?v=
# changes on every release, so a new version is a new URL.
/js/*
  Cache-Control: public, max-age=86400
/css/*
  Cache-Control: public, max-age=86400

# The service worker must always be revalidated so a new release's SW
# (and its VERSION) is picked up on the next visit, never a stale one.
/sw.js
  Cache-Control: no-cache, must-revalidate
/manifest.webmanifest
  Cache-Control: no-cache, must-revalidate
